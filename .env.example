DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=Africa/Johannesburg

# Local development uses SQLite when DATABASE_URL and POSTGRES_DB are not set.
# Production should use DATABASE_URL from the managed PostgreSQL provider.
DATABASE_URL=
DATABASE_SSL_REQUIRE=true
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432

# Hosted frontend URLs used for CORS and CSRF. Set these in production.
FRONTEND_URL=https://greenchoice-workstation.vercel.app
GREENCHOICE_FRONTEND_URL=https://greenchoice-workstation.vercel.app
CORS_ALLOWED_ORIGINS=https://greenchoice-workstation.vercel.app
CSRF_TRUSTED_ORIGINS=https://greenchoice-workstation.vercel.app

# Local development examples:
# FRONTEND_URL=http://127.0.0.1:3001
# GREENCHOICE_FRONTEND_URL=http://127.0.0.1:3001
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
# CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_SSL_REDIRECT=false

# Optional only if background workers are enabled.
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
